<?xml version="1.0" encoding="utf-8"?>
<PluginModule>
	<EffectPlugin Name="TB_Filter" CompanyID="319" PluginID="5585">
		<PluginInfo>
			<PlatformSupport>
				<Platform Name="Any">
					<CanBeInsertOnBusses>true</CanBeInsertOnBusses>
					<CanBeInsertOnAudioObjects>true</CanBeInsertOnAudioObjects>
					<CanBeRendered>true</CanBeRendered>
				</Platform>
			</PlatformSupport>
		</PluginInfo>
		<Properties>
			<Property Name="FilterType" Type="int32" DisplayName="Filter Type">
				<DefaultValue>0</DefaultValue>
				<AudioEnginePropertyID>0</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Enumeration Type="int32">
							<Value DisplayName="LowPass">0</Value>
							<Value DisplayName="HighPass">1</Value>
							<Value DisplayName="BandPass">2</Value>
							<Value DisplayName="Notch">3</Value>
						</Enumeration>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<Property Name="BaseCutoff" Type="Real32" SupportRTPCType="Additive" DisplayName="Base Cutoff (Hz)">
				<UserInterface Step="10" Fine="1" Decimals="1" UIMin="20" UIMax="20000" />
				<DefaultValue>1000.0</DefaultValue>
				<AudioEnginePropertyID>1</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>20.0</Min>
							<Max>20000.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<Property Name="FilterSlope" Type="int32" DisplayName="Filter Slope (dB/Oct)">
				<DefaultValue>1</DefaultValue>
				<AudioEnginePropertyID>2</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Enumeration Type="int32">
							<Value DisplayName="6dB">0</Value>
							<Value DisplayName="12dB">1</Value>
							<Value DisplayName="24dB">2</Value>
							<Value DisplayName="48dB">3</Value>
						</Enumeration>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<Property Name="QFactor" Type="Real32" SupportRTPCType="Additive" DisplayName="Q Factor">
				<UserInterface Step="0.1" Fine="0.01" Decimals="2" UIMin="0.1" UIMax="10.0" />
				<DefaultValue>1.0</DefaultValue>
				<AudioEnginePropertyID>3</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.1</Min>
							<Max>20.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<Property Name="AutoSweepEnabled" Type="bool" DisplayName="Auto Sweep Enabled">
				<DefaultValue>false</DefaultValue>
				<AudioEnginePropertyID>4</AudioEnginePropertyID>
			</Property>

			<Property Name="SweepTarget" Type="Real32" SupportRTPCType="Additive" DisplayName="Sweep Target (Hz)">
				<UserInterface Step="10" Fine="1" Decimals="1" UIMin="20" UIMax="20000" />
