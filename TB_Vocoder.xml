<?xml version="1.0" encoding="utf-8"?>
<PluginModule>
	<EffectPlugin Name="TB_Vocoder" CompanyID="319" PluginID="27710">
		<PluginInfo>
			<PlatformSupport>
				<Platform Name="Any">
					<CanBeInsertOnBusses>true</CanBeInsertOnBusses>
					<CanBeInsertOnAudioObjects>true</CanBeInsertOnAudioObjects>
					<CanBeRendered>true</CanBeRendered>
				</Platform>
			</PlatformSupport>
		</PluginInfo>
		<Properties>
			<!-- 0. Voice Type (Dropdown Enum - 추후 매크로 확장을 위한 더미 파라미터) -->
			<Property Name="VoiceType" Type="int32" SupportRTPCType="Exclusive" DisplayName="Voice Type">
				<DefaultValue>0</DefaultValue>
				<AudioEnginePropertyID>0</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Enumeration Type="int32">
							<Value DisplayName="Robot">0</Value>
							<Value DisplayName="Minion">1</Value>
							<Value DisplayName="Creature">2</Value>
						</Enumeration>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<!-- 1. Pitch Module -->
			<Property Name="PitchRatio" Type="Real32" SupportRTPCType="Additive" DisplayName="Pitch Ratio">
				<UserInterface Step="0.1" Fine="0.01" Decimals="2" UIMin="0.5" UIMax="2.0" />
				<DefaultValue>1.0</DefaultValue>
				<AudioEnginePropertyID>1</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.2</Min>
							<Max>4.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<!-- 2. Ring Modulator Module -->
			<Property Name="RingModFreq" Type="Real32" SupportRTPCType="Additive" DisplayName="Ring Mod Freq (Hz)">
				<UserInterface Step="10" Fine="1" Decimals="1" UIMin="10.0" UIMax="1000.0" />
				<DefaultValue>50.0</DefaultValue>
				<AudioEnginePropertyID>2</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>1.0</Min>
							<Max>5000.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>
			<Property Name="RingModMix" Type="Real32" SupportRTPCType="Additive" DisplayName="Ring Mod Mix (%)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="0.0" UIMax="100.0" />
				<DefaultValue>0.0</DefaultValue>
				<AudioEnginePropertyID>3</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.0</Min>
							<Max>100.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<!-- 3. Resonator Module -->
			<Property Name="ResonatorFreq" Type="Real32" SupportRTPCType="Additive" DisplayName="Resonance (Hz)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="40.0" UIMax="1000.0" />
				<DefaultValue>120.0</DefaultValue>
				<AudioEnginePropertyID>4</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>20.0</Min>
							<Max>2000.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>
			<Property Name="ResonatorFeedback" Type="Real32" SupportRTPCType="Additive" DisplayName="Resonator Feedback (%)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="0.0" UIMax="99.0" />
				<DefaultValue>50.0</DefaultValue>
				<AudioEnginePropertyID>5</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.0</Min>
							<Max>99.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>
			<Property Name="ResonatorMix" Type="Real32" SupportRTPCType="Additive" DisplayName="Resonator Mix (%)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="0.0" UIMax="100.0" />
				<DefaultValue>0.0</DefaultValue>
				<AudioEnginePropertyID>6</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.0</Min>
							<Max>100.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<!-- 4. Drive -->
			<Property Name="Drive" Type="Real32" SupportRTPCType="Additive" DisplayName="Drive (%)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="0.0" UIMax="100.0" />
				<DefaultValue>0.0</DefaultValue>
				<AudioEnginePropertyID>7</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.0</Min>
							<Max>100.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<!-- 5. Global Output Settings -->
			<Property Name="Mix" Type="Real32" SupportRTPCType="Additive" DisplayName="Dry/Wet Mix (%)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="0.0" UIMax="100.0" />
				<DefaultValue>100.0</DefaultValue>
				<AudioEnginePropertyID>8</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.0</Min>
							<Max>100.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>
			<Property Name="OutputGain" Type="Real32" SupportRTPCType="Additive" DisplayName="Output Gain (dB)">
				<UserInterface Step="0.5" Fine="0.1" Decimals="1" UIMin="-24.0" UIMax="12.0" />
				<DefaultValue>0.0</DefaultValue>
				<AudioEnginePropertyID>9</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>-24.0</Min>
							<Max>12.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>
		</Properties>
	</EffectPlugin>
</PluginModule>