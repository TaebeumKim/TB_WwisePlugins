<?xml version="1.0" encoding="utf-8"?>
<PluginModule>
	<EffectPlugin Name="TB_ConvolutionReverb" CompanyID="319" PluginID="16440">
		<PluginInfo>
			<PlatformSupport>
				<Platform Name="Any">
					<CanBeInsertOnBusses>true</CanBeInsertOnBusses>
					<CanBeInsertOnAudioObjects>true</CanBeInsertOnAudioObjects>
					<CanBeRendered>true</CanBeRendered>
					<!-- 미디어(IR 파일) 사용을 허락받는 필수 태그 -->
					<CanReferenceDataFile>true</CanReferenceDataFile>
				</Platform>
			</PlatformSupport>
		</PluginInfo>
		<Properties>
			<!-- 0. Stretch -->
			<Property Name="Stretch" Type="Real32" SupportRTPCType="Additive" DisplayName="IR Stretch (%)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="-50" UIMax="100" />
				<DefaultValue>0.0</DefaultValue>
				<AudioEnginePropertyID>0</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>-50.0</Min>
							<Max>100.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>
			<!-- 1. MonoIR -->
			<Property Name="MonoIR" Type="bool" SupportRTPCType="Additive" DisplayName="Force Mono IR">
				<DefaultValue>false</DefaultValue>
				<AudioEnginePropertyID>1</AudioEnginePropertyID>
			</Property>
			<!-- 2. PreDelay -->
			<Property Name="PreDelay" Type="Real32" SupportRTPCType="Additive" DisplayName="Pre-Delay (ms)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="0" UIMax="500" />
				<DefaultValue>0.0</DefaultValue>
				<AudioEnginePropertyID>2</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.0</Min>
							<Max>500.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>
			<!-- 4. Mix -->
			<Property Name="Mix" Type="Real32" SupportRTPCType="Additive" DisplayName="Dry/Wet Mix (%)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="0" UIMax="100" />
				<DefaultValue>100.0</DefaultValue>
				<AudioEnginePropertyID>3</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>0.0</Min>
							<Max>100.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>
			<!-- 5. OutputGain -->
			<Property Name="OutputGain" Type="Real32" SupportRTPCType="Additive" DisplayName="Output Gain (dB)">
				<UserInterface Step="1" Fine="0.1" Decimals="1" UIMin="-24" UIMax="24" />
				<DefaultValue>0.0</DefaultValue>
				<AudioEnginePropertyID>4</AudioEnginePropertyID>
				<Restrictions>
					<ValueRestriction>
						<Range Type="Real32">
							<Min>-24.0</Min>
							<Max>24.0</Max>
						</Range>
					</ValueRestriction>
				</Restrictions>
			</Property>

			<!-- 6. 버튼 역할을 할 가짜 체크박스 (DSP로는 전달되지 않음) -->
			<Property Name="LoadIR" Type="bool" SupportRTPCType="Exclusive" DisplayName="[ CLICK HERE ] Load IR File...">
				<DefaultValue>false</DefaultValue>
				<AudioEnginePropertyID>5</AudioEnginePropertyID>
			</Property>
		</Properties>
	</EffectPlugin>
</PluginModule>