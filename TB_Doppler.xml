          </ValueRestriction>
        </Restrictions>
      </Property>
      
      <!-- Y축 (앞뒤) 위치 파라미터 -->
      <Property Name="PositionY" Type="Real32" SupportRTPCType="Exclusive" DisplayName="Front/Back (Y)">
